<style>
/* === 404ページ固有スタイル === */
.notFound {
  text-align: center;
  padding: 20px 20px 20px;
  max-width: 1240px;
  margin: 0 auto;
}
.notFound__image {
  max-width: 1240px;
  margin: 0 auto 10px;
}
.notFound__image img {
  width: 100%;
  height: auto;
  border-radius: 8px;
}
.notFound__caption {
  font-size: 1.2rem;
  color: #888;
  margin-bottom: 30px;
}
.notFound__caption a {
  color: #888;
  text-decoration: underline;
}

/* --- 404 バウンスアニメーション --- */
.notFound__code {
  font-size: 7rem;
  font-weight: bold;
  letter-spacing: 0.15em;
  margin-bottom: 5px;
  line-height: 1;
}
.notFound__code span {
  display: inline-block;
  color: #fe7657;
  text-shadow: 0 4px 12px rgba(254, 118, 87, 0.3);
  animation: bounce404 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
             float404 2.5s ease-in-out 1.5s infinite;
  opacity: 0;
}
.notFound__code span:nth-child(1) {
  animation-delay: 0.1s, 1.5s;
}
.notFound__code span:nth-child(2) {
  animation-delay: 0.35s, 1.75s;
}
.notFound__code span:nth-child(3) {
  animation-delay: 0.6s, 2.0s;
}

@keyframes bounce404 {
  0% {
    opacity: 0;
    transform: translateY(-80px) scale(0.7) rotate(-5deg);
  }
  40% {
    opacity: 1;
    transform: translateY(8px) scaleY(0.9) scaleX(1.1) rotate(0deg);
  }
  55% {
    transform: translateY(-20px) scaleY(1.1) scaleX(0.95) rotate(2deg);
  }
  70% {
    transform: translateY(4px) scaleY(0.95) scaleX(1.03) rotate(-1deg);
  }
  85% {
    transform: translateY(-6px) scale(1.01) rotate(0deg);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1) rotate(0deg);
  }
}
@keyframes float404 {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-10px) rotate(1.5deg); }
  75% { transform: translateY(4px) rotate(-1deg); }
}

.notFound__title {
  font-size: 2.4rem;
  font-weight: bold;
  margin-bottom: 15px;
  color: #333;
}
.notFound__message {
  font-size: 1.5rem;
  color: #666;
  margin-bottom: 30px;
  line-height: 1.8;
}
.notFound__search {
  max-width: 500px;
  margin: 0 auto 20px;
}
@media screen and (max-width: 768px) {
  .notFound { padding: 40px 0 0; }
  .notFound__code { font-size: 5rem; }
  .notFound__title { font-size: 2rem; }
  .notFound__message { font-size: 1.3rem; padding: 0 15px; }
  .notFound__search { padding: 0 15px; }
}
</style>
</head>
